# Create .gitignore file
echo "__pycache__/" > .gitignore
echo "*.pyc" >> .gitignore
echo "*.db" >> .gitignore
echo "*.sqlite" >> .gitignore
echo "instance/" >> .gitignore
echo "uploads/*.xlsx" >> .gitignore
echo "uploads/*.csv" >> .gitignore
echo ".env" >> .gitignore
echo "venv/" >> .gitignore
echo "env/" >> .gitignore
echo ".DS_Store" >> .gitignore
echo "Thumbs.db" >> .gitignore